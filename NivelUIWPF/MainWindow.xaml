<Window x:Class="NivelUIWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NivelUIWPF"
        mc:Ignorable="d"
        Title="Evidenta Studenti" Height="680" Width="900">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Meniu stanga: panel cu butoane -->
        <StackPanel Grid.Column="0"
                    Orientation="Vertical"
                    Margin="0,0,15,0">
            <Button x:Name="btnMeniuAdauga"
                    Content="_Adauga+Afiseaza"
                    Height="40"
                    FontSize="14"
                    Margin="0,0,0,10"
                    Click="btnMeniuAdauga_Click"/>
            <Button x:Name="btnMeniuCauta"
                    Content="_Cauta"
                    Height="40"
                    FontSize="14"
                    Click="btnMeniuCauta_Click"/>
        </StackPanel>

        <!-- Zona de continut: doua panel-uri suprapuse, comutate prin Visibility -->
        <Grid Grid.Column="1">

            <!-- Panel Adauga+Afiseaza -->
            <Grid x:Name="panelAdauga" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <Label Content="_Nume"
                           Target="{Binding ElementName=txtNume}"
                           FontWeight="Bold"
                           Padding="0"
                           Margin="0,0,0,6"/>
                    <TextBox x:Name="txtNume"
                             Height="30"
                             FontSize="14"
                             Padding="8,0"
                             VerticalContentAlignment="Center"
                             MaxLength="15"
                             Text="{Binding StudentCurent.Nume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock x:Name="tbErrNume"
                               Text=""
                               FontSize="11"
                               Foreground="Red"
                               Margin="0,4,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,0,0,10">
                    <Label Content="_Prenume"
                           Target="{Binding ElementName=txtPrenume}"
                           FontWeight="Bold"
                           Padding="0"
                           Margin="0,0,0,6"/>
                    <TextBox x:Name="txtPrenume"
                             Height="30"
                             FontSize="14"
                             Padding="8,0"
                             VerticalContentAlignment="Center"
                             MaxLength="15"/>
                    <TextBlock x:Name="tbErrPrenume"
                               Text=""
                               FontSize="11"
                               Foreground="Red"
                               Margin="0,4,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,0,0,10">
                    <Label Content="N_ote (separate prin spatiu)"
                           Target="{Binding ElementName=txtNote}"
                           FontWeight="Bold"
                           Padding="0"
                           Margin="0,0,0,6"/>
                    <TextBox x:Name="txtNote"
                             Height="30"
                             FontSize="14"
                             Padding="8,0"
                             VerticalContentAlignment="Center"/>
                    <TextBlock x:Name="tbErrNote"
                               Text=""
                               FontSize="11"
                               Foreground="Red"
                               Margin="0,4,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="0,0,0,10">
                    <Label Content="Program de studiu"
                           FontWeight="Bold"
                           Padding="0"
                           Margin="0,0,0,6"/>
                    <WrapPanel Orientation="Horizontal">
                        <RadioButton x:Name="rbCalculatoare"
                                     Content="Calculatoare"
                                     GroupName="ProgramStudiu"
                                     IsChecked="True"
                                     Margin="0,0,20,6"/>
                        <RadioButton x:Name="rbAutomatica"
                                     Content="Automatica"
                                     GroupName="ProgramStudiu"
                                     Margin="0,0,20,6"/>
                        <RadioButton x:Name="rbElectronica"
                                     Content="Electronica"
                                     GroupName="ProgramStudiu"
                                     Margin="0,0,20,6"/>
                        <RadioButton x:Name="rbElectrotehnica"
                                     Content="Electrotehnica"
                                     GroupName="ProgramStudiu"
                                     Margin="0,0,20,6"/>
                        <RadioButton x:Name="rbEnergetica"
                                     Content="Energetica"
                                     GroupName="ProgramStudiu"
                                     Margin="0,0,20,6"/>
                        <RadioButton x:Name="rbInginerieEconomica"
                                     Content="Inginerie Economica"
                                     GroupName="ProgramStudiu"
                                     Margin="0,0,20,6"/>
                    </WrapPanel>
                </StackPanel>

                <StackPanel Grid.Row="4" Margin="0,0,0,10">
                    <Label Content="Discipline"
                           FontWeight="Bold"
                           Padding="0"
                           Margin="0,0,0,6"/>
                    <WrapPanel Orientation="Horizontal">
                        <CheckBox x:Name="cbPIU"
                                  Content="PIU"
                                  Margin="0,0,20,6"
                                  Checked="Disciplina_CheckedChanged"
                                  Unchecked="Disciplina_CheckedChanged"/>
                        <CheckBox x:Name="cbPCLP"
                                  Content="PCLP"
                                  Margin="0,0,20,6"
                                  Checked="Disciplina_CheckedChanged"
                                  Unchecked="Disciplina_CheckedChanged"/>
                        <CheckBox x:Name="cbPOO"
                                  Content="POO"
                                  Margin="0,0,20,6"
                                  Checked="Disciplina_CheckedChanged"
                                  Unchecked="Disciplina_CheckedChanged"/>
                        <CheckBox x:Name="cbDCE"
                                  Content="DCE"
                                  Margin="0,0,20,6"
                                  Checked="Disciplina_CheckedChanged"
                                  Unchecked="Disciplina_CheckedChanged"/>
                        <CheckBox x:Name="cbFizica"
                                  Content="Fizica"
                                  Margin="0,0,20,6"
                                  Checked="Disciplina_CheckedChanged"
                                  Unchecked="Disciplina_CheckedChanged"/>
                    </WrapPanel>
                </StackPanel>

                <StackPanel Grid.Row="5" Margin="0,0,0,10">
                    <Label Content="Forma de finantare"
                           FontWeight="Bold"
                           Padding="0"
                           Margin="0,0,0,6"/>
                    <ListBox x:Name="lbFormaFinantare"
                             SelectionMode="Single"
                             Height="70"
                             FontSize="13"/>
                </StackPanel>

                <StackPanel Grid.Row="6"
                            Orientation="Horizontal"
                            Margin="0,10,0,10">
                    <Button x:Name="btnSalveaza"
                            Content="_Salveaza"
                            Width="100"
                            Height="32"
                            Margin="0,0,8,0"
                            Click="btnSalveaza_Click"/>
                    <Button x:Name="btnActualizeaza"
                            Content="Act_ualizeaza"
                            Width="100"
                            Height="32"
                            Margin="0,0,8,0"
                            IsEnabled="False"
                            Click="btnActualizeaza_Click"/>
                    <Button x:Name="btnReseteaza"
                            Content="_Reset"
                            Width="80"
                            Height="32"
                            Click="btnReseteaza_Click"/>
                    <TextBlock x:Name="tbWarningActualizare"
                               Text="Efectueaza click pe  butonul Actualizeaza dupa modificarea numelui pentru a actualiza si fisierul cu date!"
                               Foreground="DarkOrange"
                               FontStyle="Italic"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               TextWrapping="Wrap"
                               MaxWidth="290"
                               Visibility="Collapsed"/>
                </StackPanel>

                <Label x:Name="lblNrStudenti"
                       Grid.Row="7"
                       FontWeight="Bold"
                       Margin="0,0,0,6"/>

                <DataGrid x:Name="dgStudenti"
                          Grid.Row="8"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="All"
                          AlternatingRowBackground="#F5F5F5"
                          RowHeight="26"
                          SelectionChanged="dgStudenti_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Id" Binding="{Binding IdStudent}" Width="60"/>
                        <DataGridTextColumn Header="Nume" Binding="{Binding Nume}" Width="130"/>
                        <DataGridTextColumn Header="Prenume" Binding="{Binding Prenume}" Width="130"/>
                        <DataGridTextColumn Header="Note" Binding="{Binding NoteAfisare}" Width="*"/>
                        <DataGridTextColumn Header="Program" Binding="{Binding ProgramSTD}" Width="130"/>
                        <DataGridTextColumn Header="Discipline" Binding="{Binding DisciplineAfisare}" Width="160"/>
                        <DataGridTextColumn Header="Forma finantare" Binding="{Binding FormaFinantare}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Panel Cauta -->
            <Grid x:Name="panelCauta" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <Label Content="Nume student"
                           Target="{Binding ElementName=txtCautareNume}"
                           FontWeight="Bold"
                           Padding="0"
                           Margin="0,0,0,6"/>
                    <TextBox x:Name="txtCautareNume"
                             Height="30"
                             FontSize="14"
                             Padding="8,0"
                             VerticalContentAlignment="Center"
                             MaxLength="15"/>
                </StackPanel>

                <Button x:Name="btnCauta"
                        Grid.Row="1"
                        Content="Cauta"
                        HorizontalAlignment="Left"
                        Width="180"
                        Height="32"
                        Margin="0,0,0,10"
                        Click="btnCauta_Click"/>

                <Label x:Name="lblNrStudentiGasiti"
                       Grid.Row="2"
                       FontWeight="Bold"
                       Margin="0,0,0,6"/>

                <DataGrid x:Name="dgStudentiGasiti"
                          Grid.Row="3"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="All"
                          AlternatingRowBackground="#F5F5F5"
                          RowHeight="26">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Id" Binding="{Binding IdStudent}" Width="60"/>
                        <DataGridTextColumn Header="Nume" Binding="{Binding Nume}" Width="130"/>
                        <DataGridTextColumn Header="Prenume" Binding="{Binding Prenume}" Width="130"/>
                        <DataGridTextColumn Header="Note" Binding="{Binding NoteAfisare}" Width="*"/>
                        <DataGridTextColumn Header="Program" Binding="{Binding ProgramSTD}" Width="130"/>
                        <DataGridTextColumn Header="Discipline" Binding="{Binding DisciplineAfisare}" Width="160"/>
                        <DataGridTextColumn Header="Forma finantare" Binding="{Binding FormaFinantare}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

        </Grid>
    </Grid>
</Window>
