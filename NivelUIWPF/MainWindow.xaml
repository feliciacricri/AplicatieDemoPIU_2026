<Window x:Class="NivelUIWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NivelUIWPF"
        mc:Ignorable="d"
        Title="Evidenta Studenti" Height="680" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <Label Content="_Nume"
                   Target="{Binding ElementName=txtNume}"
                   FontWeight="Bold"
                   Padding="0"
                   Margin="0,0,0,6"/>
            <TextBox x:Name="txtNume"
                     Height="30"
                     FontSize="14"
                     Padding="8,0"
                     VerticalContentAlignment="Center"
                     MaxLength="15"/>
            <TextBlock x:Name="tbErrNume"
                       Text=""
                       FontSize="11"
                       Foreground="Red"
                       Margin="0,4,0,0"
                       Visibility="Collapsed"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <Label Content="_Prenume"
                   Target="{Binding ElementName=txtPrenume}"
                   FontWeight="Bold"
                   Padding="0"
                   Margin="0,0,0,6"/>
            <TextBox x:Name="txtPrenume"
                     Height="30"
                     FontSize="14"
                     Padding="8,0"
                     VerticalContentAlignment="Center"
                     MaxLength="15"/>
            <TextBlock x:Name="tbErrPrenume"
                       Text=""
                       FontSize="11"
                       Foreground="Red"
                       Margin="0,4,0,0"
                       Visibility="Collapsed"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <Label Content="N_ote (separate prin spatiu)"
                   Target="{Binding ElementName=txtNote}"
                   FontWeight="Bold"
                   Padding="0"
                   Margin="0,0,0,6"/>
            <TextBox x:Name="txtNote"
                     Height="30"
                     FontSize="14"
                     Padding="8,0"
                     VerticalContentAlignment="Center"/>
            <TextBlock x:Name="tbErrNote"
                       Text=""
                       FontSize="11"
                       Foreground="Red"
                       Margin="0,4,0,0"
                       Visibility="Collapsed"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <Label Content="Program de studiu"
                   FontWeight="Bold"
                   Padding="0"
                   Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="rbCalculatoare"
                             Content="Calculatoare"
                             GroupName="ProgramStudiu"
                             IsChecked="True"
                             Margin="0,0,20,0"/>
                <RadioButton x:Name="rbAutomatica"
                             Content="Automatica"
                             GroupName="ProgramStudiu"
                             Margin="0,0,20,0"/>
                <RadioButton x:Name="rbElectronica"
                             Content="Electronica"
                             GroupName="ProgramStudiu"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    Margin="0,10,0,10">
            <Button x:Name="btnSalveaza"
                    Content="_Salveaza Student"
                    Width="180"
                    Height="32"
                    Margin="0,0,10,0"
                    Click="btnSalveaza_Click"/>
            <Button x:Name="btnReseteaza"
                    Content="_Reset"
                    Width="180"
                    Height="32"
                    Click="btnReseteaza_Click"/>
        </StackPanel>

        <Label x:Name="lblNrStudenti"
               Grid.Row="5"
               FontWeight="Bold"
               Margin="0,0,0,6"/>

        <DataGrid x:Name="dgStudenti"
                Grid.Row="6"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                HeadersVisibility="Column"
                GridLinesVisibility="All"
                AlternatingRowBackground="#F5F5F5"
                RowHeight="26">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding IdStudent}" Width="60"/>
                <DataGridTextColumn Header="Nume" Binding="{Binding Nume}" Width="130"/>
                <DataGridTextColumn Header="Prenume" Binding="{Binding Prenume}" Width="130"/>
                <DataGridTextColumn Header="Note" Binding="{Binding NoteAfisare}" Width="*"/>
                <DataGridTextColumn Header="Program" Binding="{Binding ProgramSTD}" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
